# AubeVideo - Variables d'environnement

# Clé de session (OBLIGATOIRE en prod) : openssl rand -hex 32
AUBEVIDEO_SECRET=change-me-with-a-random-string

# --- Base de données ---
# Option 1 (cloud : Render/Railway/Fly/Heroku) : une seule URL suffit.
# DATABASE_URL=postgres://user:pass@host:5432/aubevideo
# Option 2 (champs séparés) :
AUBEVIDEO_DB=aubevideo
AUBEVIDEO_DB_USER=aubevideo_user
AUBEVIDEO_DB_PASS=CHANGE_ME
AUBEVIDEO_DB_HOST=localhost
AUBEVIDEO_DB_PORT=5432
# sslmode : "require" pour un Postgres managé, vide en local
AUBEVIDEO_DB_SSLMODE=

# --- Auth ---
# 1 = autorise le fallback SSO PAM (écosystème). 0 = email/mot de passe uniquement (cloud).
AUBEVIDEO_PAM_LOGIN=1
# 1 = bypass PAM en dev local (n'importe quels identifiants). NE JAMAIS activer en prod.
AUBEVIDEO_DEV_MODE=0

# --- Stockage / proxy ---
AUBEVIDEO_UPLOADS=/var/www/aubevideo/uploads
AUBEVIDEO_QUOTA=10737418240
AUBEVIDEO_BEHIND_PROXY=0
AUBEVIDEO_HTTPS=0
PORT=5017
