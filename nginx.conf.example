# /etc/nginx/sites-available/aubevideo
# Puis: ln -s ... /etc/nginx/sites-enabled/ && certbot --nginx -d video.aubeetoilee.com

server {
    listen 80;
    server_name video.aubeetoilee.com;

    client_max_body_size 2G;

    location / {
        proxy_pass http://127.0.0.1:5017;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
        proxy_request_buffering off;
    }

    # Streaming vidéo — désactive le buffering pour le range
    location /stream/ {
        proxy_pass http://127.0.0.1:5017;
        proxy_set_header Host $host;
        proxy_buffering off;
        proxy_cache off;
        proxy_request_buffering off;
        proxy_http_version 1.1;
    }
}
