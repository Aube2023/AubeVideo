    <path android:pathData="M54,54 m-17,0 a17,17 0 1,1 34,0 a17,17 0 1,1 -34,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="49"
                android:centerY="48"
                android:gradientRadius="26">
                <item android:offset="0" android:color="#FFE39A"/>
                <item android:offset="0.5" android:color="#F7B545"/>
                <item android:offset="1" android:color="#E8851C"/>
